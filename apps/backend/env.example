# نسخ هذا الملف إلى .env وتعديل القيم

# قاعدة البيانات - محلي:
DATABASE_PROVIDER=sqlite
DATABASE_URL=file:./dev.db

# قاعدة البيانات - إنتاج Railway:
# DATABASE_PROVIDER=postgresql
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/kulldb

# JWT
JWT_SECRET=CHANGE_THIS_TO_RANDOM_LONG_STRING
JWT_EXPIRES_IN=7d

# الخادم
PORT=3001
NODE_ENV=development

# رابط الواجهة - محلي:
FRONTEND_URL=http://localhost:5173
# رابط الواجهة - إنتاج:
# FRONTEND_URL=https://kull-app.vercel.app
